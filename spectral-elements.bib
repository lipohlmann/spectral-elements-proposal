  publisher = {Taylor \& Francis},
  issn = {0029-5639},
  doi = {10.13182/NSE132-312},
  url = {https://doi.org/10.13182/NSE132-312},
  urldate = {2026-05-16},
  abstract = {The traditional second-order self-adjoint forms of the transport equation are the even- and odd-parity equations. A useful alternative to these equations exists in the form of a second-order self-adjoint equation that has the angular flux as its unknown. The numerical advantages and disadvantages of this equation are contrasted both theoretically and computationally with those of the even- and odd-parity equations.},
