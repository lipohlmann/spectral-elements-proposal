  author       = {Bjøntegaard, Tormod and Rønquist, Einar M. and Tråsdahl, Øystein},
  date         = {2012-09},
  journaltitle = {Journal of Scientific Computing},
  shortjournal = {J Sci Comput},
  volume       = {52},
